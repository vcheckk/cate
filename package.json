{
  "name": "cate",
  "version": "0.3.0",
  "productName": "Cate",
  "description": "An infinite zoomable canvas IDE",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/0-AI-UG/cate.git"
  },
  "homepage": "https://github.com/0-AI-UG/cate",
  "bugs": {
    "url": "https://github.com/0-AI-UG/cate/issues"
  },
  "author": {
    "name": "0-AI UG",
    "email": "hello@0-ai.org"
  },
  "main": "dist/main/index.js",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "postinstall": "bash scripts/patch-electron-name.sh",
    "predev": "bash scripts/patch-electron-name.sh",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:smoke:electron": "node scripts/run-electron-smoke.mjs",
    "preview": "electron-vite preview",
    "icons": "node scripts/generate-icons.js",
    "package": "npm run icons && electron-vite build && electron-builder",
    "package:mac": "npm run icons && electron-vite build && electron-builder --mac",
    "package:win": "npm run icons && electron-vite build && electron-builder --win",
    "package:linux": "npm run icons && electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "chokidar": "^4.0.0",
    "electron-log": "^5.4.3",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.8.3",
    "monaco-editor": "^0.52.0",
    "node-pty": "^1.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "simple-git": "^3.27.0",
    "use-sync-external-store": "^1.6.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.0",
    "sharp": "^0.33.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.4"
  }
}
